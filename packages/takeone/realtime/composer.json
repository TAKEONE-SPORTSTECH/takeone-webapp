{
    "name": "takeone/realtime",
    "description": "Self-hosted MQTT realtime plugin for Laravel — instant notifications & 1:1 messaging. Drop-in, broker included.",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": ["laravel", "mqtt", "realtime", "websockets", "notifications", "chat"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "php-mqtt/laravel-client": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Takeone\\Realtime\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Takeone\\Realtime\\RealtimeServiceProvider"
            ],
            "aliases": {
                "Realtime": "Takeone\\Realtime\\Facades\\Realtime"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
