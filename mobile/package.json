{
    "name": "takeone-android",
    "version": "1.0.0",
    "private": true,
    "description": "TAKEONE — native Android shell (Capacitor) wrapping the TAKEONE web app.",
    "scripts": {
        "sync": "cap sync android",
        "assets": "capacitor-assets generate --android",
        "open": "cap open android",
        "build:debug": "cd android && ./gradlew assembleDebug",
        "build:release": "cd android && ./gradlew bundleRelease"
    },
    "dependencies": {
        "@capacitor/android": "^6.2.0",
        "@capacitor/app": "^6.0.2",
        "@capacitor/core": "^6.2.0",
        "@capacitor/splash-screen": "^6.0.3",
        "@capacitor/status-bar": "^6.0.2"
    },
    "devDependencies": {
        "@capacitor/assets": "^3.0.5",
        "@capacitor/cli": "^6.2.0",
        "sharp": "^0.33.5"
    }
}
