APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production: switch to JSON for log aggregators (Datadog, Logtail, CloudWatch)
# LOG_CHANNEL=json

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sentry — error monitoring
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
# In production set LOG_STACK=single,sentry to forward Log::error() calls to Sentry

# Horizon — queue dashboard (super-admin only at /horizon)
# Switch QUEUE_CONNECTION=redis when Redis is available on the server
HORIZON_NAME="${APP_NAME}"
# HORIZON_PATH=horizon

# ── TAKEONE Realtime (MQTT plugin) ──────────────────────────────────────────
REALTIME_ENABLED=false
REALTIME_MQTT_HOST=127.0.0.1
REALTIME_MQTT_PORT=1883
REALTIME_MQTT_USERNAME=takeone-server
REALTIME_MQTT_PASSWORD=
REALTIME_MQTT_WS_URL=ws://127.0.0.1:8083/mqtt

# ── TAKEONE MCP Server (Model Context Protocol) ─────────────────────────────
# General-purpose MCP server exposing the platform to external systems.
# HTTP: POST /mcp with a Sanctum bearer token (php artisan mcp:token {user}).
# stdio: php artisan mcp:start takeone (acts as MCP_STDIO_USER_ID).
MCP_ENABLED=true
MCP_ALLOW_WRITES=true
# User id the local (stdio) server acts as. Leave blank to disable stdio writes.
MCP_STDIO_USER_ID=
MCP_PAGE_SIZE=25
MCP_MAX_PAGE_SIZE=100
REALTIME_JWT_SECRET=
REALTIME_JWT_TTL=3600

# Firebase Cloud Messaging — native Android push (app tray notifications when closed).
# Download the service-account JSON from Firebase console → Project settings →
# Service accounts → Generate new private key, and save it as:
#   storage/app/firebase/service-account.json   (default path — no need to set FCM_CREDENTIALS)
# Set FCM_ENABLED=false to disable push entirely.
FCM_ENABLED=true
# FCM_CREDENTIALS=/absolute/path/to/service-account.json
